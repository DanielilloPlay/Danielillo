Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"cd", "=", 
    RowBox[{"CovDOfMetric", "[", "g", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"gmatrix", "=", " ", 
   RowBox[{
    RowBox[{"ComponentArray", "[", 
     RowBox[{"g", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "a"}], ",", 
         RowBox[{"-", "ch"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
