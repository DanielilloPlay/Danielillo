Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"n", "[", "a", "]"}], 
    RowBox[{"l", "[", "b", "]"}], 
    RowBox[{"n", "[", "c", "]"}], 
    RowBox[{"l", "[", "d", "]"}], 
    RowBox[{
     RowBox[{"cd", "[", "e", "]"}], "@", 
     RowBox[{
      RowBox[{"cd", "[", 
       RowBox[{"-", "e"}], "]"}], "@", 
      RowBox[{
       RowBox[{"Weyl", "[", "cd", "]"}], "[", 
       RowBox[{
        RowBox[{"-", "a"}], ",", 
        RowBox[{"-", "b"}], ",", 
        RowBox[{"-", "c"}], ",", 
        RowBox[{"-", "d"}]}], "]"}]}]}]}], "==", 
   RowBox[{
    RowBox[{"-", "2"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"cd", "[", 
        RowBox[{"-", "a"}], "]"}], "@", 
       RowBox[{
        RowBox[{"cd", "[", "a", "]"}], "@", "\[Psi]2"}]}], "-", 
      RowBox[{"12", " ", 
       RowBox[{"\[Rho]", "^", "2"}], "\[Psi]2"}]}], ")"}]}]}], "//", 
  "Simplify"}]], "Input",
