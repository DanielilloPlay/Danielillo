         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"AChristoffel[covd1, covd2][A, -b, -C] returns the \
Christoffel tensor relating the connections covd1 and covd2 on an inner \
vbundle, and defines it if it does not exist yet. This proceeds by immediate \
conversion of AChristoffel into Christoffel. AChristoffel[covd][A, -b, -C} is \
equivalent to AChristoffel[covd, PD][A, -b, -C].\"\>", "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
