Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Generamos", " ", "la", " ", "variedad", " ", "y", " ", "la", " ", 
    "metrica", " ", "de", " ", "Minkowski"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"DefManifold", "[", 
     RowBox[{"M", ",", "4", ",", 
      RowBox[{"IndexRange", "[", 
       RowBox[{"a", ",", "f"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DefChart", "[", 
     RowBox[{"ch", ",", "M", ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1", ",", "2", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"t", "[", "]"}], ",", 
        RowBox[{"x", "[", "]"}], ",", 
        RowBox[{"y", "[", "]"}], ",", 
        RowBox[{"z", "[", "]"}]}], "}"}], ",", 
      RowBox[{"ChartColor", " ", "->", " ", "Blue"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DefConstantSymbol", "[", 
     RowBox[{"mass", ",", " ", 
      RowBox[{"PrintAs", "->", " ", "\"\<M\>\""}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Las", " ", "funciones", " ", "que", " ", "hay", " ", "que", " ", 
     "hallar"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DefScalarFunction", "[", 
     RowBox[{"HM", ",", " ", 
      RowBox[{
      "PrintAs", "->", "\"\<\!\(\*SubscriptBox[\(h\), \(+\)]\)\>\""}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DefScalarFunction", "[", 
     RowBox[{"Hm", ",", 
      RowBox[{
      "PrintAs", "->", "\"\<\!\(\*SubscriptBox[\(h\), \(-\)]\)\>\""}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"$Assumptions", " ", "=", " ", 
     RowBox[{
      RowBox[{"mass", " ", ">", "0"}], " ", "&&", " ", 
      RowBox[{
       RowBox[{"x", "[", "]"}], "\[Element]", "Reals"}], "&&", " ", 
      RowBox[{
       RowBox[{"y", "[", "]"}], "\[Element]", "Reals"}], " ", "&&", " ", 
      RowBox[{
       RowBox[{"z", "[", "]"}], "\[Element]", "Reals"}], "&&", " ", 
      RowBox[{
       RowBox[{"t", "[", "]"}], "\[Element]", "Reals"}]}]}], ";"}], " ", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"\[Eta]", "=", 
      RowBox[{"CTensor", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "0", ",", "1"}], "}"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "ch"}], ",", 
          RowBox[{"-", "ch"}]}], "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"SetCMetric", "[", 
      RowBox[{"\[Eta]", ",", "ch", ",", 
       RowBox[{"SignatureOfMetric", "->", 
        RowBox[{"{", 
         RowBox[{"1", ",", "3", ",", "0"}], "}"}]}]}], "]"}], ";"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DefMetric", "[", 
     RowBox[{
      RowBox[{"-", "1"}], ",", 
      RowBox[{"\[Eta]", "[", 
       RowBox[{
        RowBox[{"-", "a"}], ",", 
        RowBox[{"-", "b"}]}], "]"}], ",", "cd"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DefMetricPerturbation", "[", 
     RowBox[{"\[Eta]", ",", "H", ",", "\[Omega]"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gmatrix", "=", " ", 
     RowBox[{
      RowBox[{"ComponentArray", "[", 
       RowBox[{"\[Eta]", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "a"}], ",", 
           RowBox[{"-", "ch"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "b"}], ",", 
           RowBox[{"-", "ch"}]}], "}"}]}], "]"}], "]"}], " ", "//", " ", 
      "MatrixForm"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"cd", "=", 
      RowBox[{"CovDOfMetric", "[", "g", "]"}]}], ";"}], "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.949807162095414*^9, 3.9498071852783823`*^9}, {
