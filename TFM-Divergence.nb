Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Definimos", " ", "una", " ", "subvariedad", " ", "de", " ", "M"}],
    "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "submanifold", " ", "\[CapitalSigma]3", " ", "with", " ", 
    "dimension", " ", "3"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Definir", " ", "subvariedad", " ", "\[CapitalSigma]3", " ", "de", " ", 
    "dimensi\[OAcute]n", " ", "3"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"DefManifold", "[", 
     RowBox[{"S3", ",", "3", ",", 
      RowBox[{"{", 
       RowBox[{"P", ",", "Q", ",", "R"}], "}"}]}], "]"}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Declare", " ", "that\[CapitalSigma]3", " ", "is", " ", "embedded", " ", 
     "in", " ", "M"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Declarar", " ", "que", " ", "\[CapitalSigma]3", " ", "est\[AAcute]", " ",
      "embebida", " ", "en", " ", "M"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DefSubmanifold", "[", 
     RowBox[{"S3", ",", "M"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "metric", " ", "in", " ", "\[CapitalSigma]3", "  ", "with",
      " ", "positive", " ", "sign", " ", 
     RowBox[{"(", "euclidean", ")"}]}], " ", "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Definir", " ", "m\[EAcute]trica", " ", "en", " ", "\[CapitalSigma]3", 
     " ", "con", " ", "signo", " ", "positivo", " ", 
     RowBox[{"(", "eucl\[IAcute]deo", ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DefMetric", "[", 
     RowBox[{
      RowBox[{"+", "1"}], ",", 
      RowBox[{"h", "[", 
       RowBox[{
        RowBox[{"-", "P"}], ",", 
        RowBox[{"-", "Q"}]}], "]"}], ",", "D3", ",", 
      RowBox[{"PrintAs", "->", "\"\<h\>\""}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Rule", " ", "to", " ", "the", " ", "identity", " ", "metric", " ", 
      RowBox[{"product", "  ", ":", 
       RowBox[{"h_", 
        RowBox[{"{", "ij", "}"}], " ", 
        RowBox[{"v", "^", "j"}]}]}]}], "=", "v_i"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Regla", " ", "para", " ", "el", " ", "producto", " ", "m\[EAcute]trico",
       " ", 
      RowBox[{"identidad", ":", 
       RowBox[{"h_", 
        RowBox[{"{", "ij", "}"}], " ", 
        RowBox[{"v", "^", "j"}]}]}]}], "=", "v_i"}], "*)"}], 
   RowBox[{
    RowBox[{"metricRules3D", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"h", "[", 
          RowBox[{
           RowBox[{"-", "P"}], ",", 
           RowBox[{"-", "Q"}]}], "]"}], " ", 
         RowBox[{"h", "[", 
          RowBox[{"Q", ",", 
           RowBox[{"-", "R"}]}], "]"}]}], ":>", 
        RowBox[{"KroneckerDelta", "[", 
         RowBox[{
          RowBox[{"-", "P"}], ",", 
          RowBox[{"-", "R"}]}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"h", "[", 
         RowBox[{
          RowBox[{"-", "P"}], ",", "P"}], "]"}], "->", "3"}]}], "  ", 
      RowBox[{"(*", 
       RowBox[{"traza", "=", "3"}], "*)"}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "Alpha", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DefTensor", "[", 
     RowBox[{
      RowBox[{"Alpha", "[", 
       RowBox[{"P", ",", 
        RowBox[{"-", "a"}], ",", 
        RowBox[{"-", "b"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"S3", ",", "M"}], "}"}], ",", 
      RowBox[{"Antisymmetric", "[", 
       RowBox[{"{", 
        RowBox[{"2", ",", "3"}], "}"}], "]"}], ",", 
      RowBox[{"PrintAs", "->", "\"\<\[Alpha]\>\""}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "rules", " ", "of", " ", "scalar", " ", "product"}], 
    "*)"}], "\[IndentingNewLine]", 
