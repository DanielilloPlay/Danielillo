Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "We", " ", "now", " ", "calculate", " ", "all", " ", "possible", " ", 
    "combinations", " ", "for", " ", "the", " ", 
    RowBox[{"D", "'"}], "Alembertian", " ", "with", " ", "NP", " ", 
    "formalism"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Calculamos", " ", "ahora", " ", "todas", " ", "las", " ", "combinaciones",
     " ", "posibles", " ", "para", " ", "el", " ", 
    RowBox[{"D", "'"}], "Alembertiano", " ", "con", " ", "el", " ", 
    "formalismo", " ", "NP"}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"We", " ", "generate", " ", "a", " ", "list"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Generamos", " ", "una", " ", "lista"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"vecs", "=", 
     RowBox[{"{", 
      RowBox[{"l", ",", "n", ",", "m", ",", "mb"}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"The", " ", "combinations"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Las", " ", "combinaciones"}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"comb", "=", 
     RowBox[{"Tuples", "[", 
      RowBox[{"vecs", ",", "3"}], "]"}]}], ";"}], "   ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"4", "^", "3"}], "=", "64"}], "*)"}], "\[IndentingNewLine]", 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Definition", " ", "of", " ", "the", " ", "64", " ", "projections", " ", 
     "using", " ", "Table", " ", "and", " ", "comb"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Definici\[OAcute]n", " ", "de", " ", "las", " ", "64", " ", 
     "proyecciones", " ", "utilizando", " ", "Table", " ", "y", " ", "comb"}],
     "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dlist", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"CD", "[", "a", "]"}], "@", 
            RowBox[{"Cweyl", "[", 
             RowBox[{
              RowBox[{"-", "a"}], ",", 
              RowBox[{"-", "b"}], ",", 
              RowBox[{"-", "c"}], ",", 
              RowBox[{"-", "d"}]}], "]"}]}], " ", 
           RowBox[{
            RowBox[{"comb", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}], "[", "b", "]"}], " ", 
           RowBox[{
            RowBox[{"comb", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "2"}], "]"}], "]"}], "[", "c", "]"}], " ", 
           RowBox[{
            RowBox[{"comb", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "3"}], "]"}], "]"}], "[", "d", "]"}]}], "/.", 
          " ", "Pacorule"}], "//", "Simplification"}], "//", "FullSimplify"}],
        ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "[", "comb", "]"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Assign", " ", "names", " ", "d1"}], ",", "d2", ",", "...", ",", 
     "d256"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Asignar", " ", "nombres", " ", "d1"}], ",", "d2", ",", "...", 
     ",", "d256"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Symbol", "[", 
        RowBox[{"\"\<d\>\"", "<>", 
         RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "=", 
       RowBox[{"dlist", "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "64"}], "}"}]}], "]"}], ";"}], "\n"}]}]], "Input",
