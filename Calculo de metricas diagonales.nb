Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"lis", "=", 
   RowBox[{"ComponentArray", "[", 
    RowBox[{
     RowBox[{"Christoffel", "[", 
      RowBox[{"cd", ",", "PDch"}], "]"}], "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", "ch"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "b"}], ",", 
        RowBox[{"-", "ch"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "c"}], ",", 
        RowBox[{"-", "ch"}]}], "}"}]}], "]"}], "]"}]}], " ", 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"list", "=", " ", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"UnsameQ", "[", 
        RowBox[{
         RowBox[{"lis", "[", 
          RowBox[{"[", 
           RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "]"}], 
          "]"}], ",", "0"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Subscript", "[", 
          RowBox[{
           RowBox[{"Superscript", "[", 
            RowBox[{"\"\<\[CapitalGamma]\>\"", ",", 
             RowBox[{"\[Alpha]", "-", "1"}]}], "]"}], ",", 
           RowBox[{"\[Beta]", "-", "1"}], ",", 
           RowBox[{"\[Gamma]", "-", "1"}]}], "]"}], ",", 
